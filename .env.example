# ============================================================
# Marine Minds 29 — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Supabase — get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key — ONLY used in server-side code / admin actions
# Keep this secret — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used for auth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Restrict signup to class emails only (e.g. @unaab.edu.ng)
# Leave blank to allow any email
ALLOWED_EMAIL_DOMAIN=

# Optional: Admin passcode for accessing admin panel
ADMIN_SECRET_CODE=marineminds2029
